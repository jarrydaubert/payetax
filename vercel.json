{
  "installCommand": "bun install --frozen-lockfile",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.payetax.co.uk"
        }
      ],
      "destination": "https://payetax.co.uk/:path*",
      "permanent": true
    },
    {
      "source": "/blog/scottish-vs-english-tax-rates-2025-comparison",
      "destination": "/blog/scottish-vs-english-tax-rates-2026-comparison",
      "permanent": true
    },
    {
      "source": "/tools/director-calculator",
      "destination": "/tools/director-guide",
      "permanent": true
    }
  ]
}

{
  "name": "payetax",
  "version": "3.6.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "bundle:analyze": "node scripts/bundle-analyzer.js",
    "bundle:monitor": "npm run build && npm run bundle:analyze",
    "start": "next start",
    "test": "jest --coverage && open audit-outputs/coverage/lcov-report/index.html",
    "test:watch": "jest --watch",
    "test:no-coverage": "jest --no-coverage",
    "test:changed": "jest --onlyChanged --no-coverage",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit --project='Mobile Chrome' --project='Mobile Safari' && open audit-outputs/playwright-report/index.html",
    "test:dev": "playwright test --project=chromium && open audit-outputs/playwright-report/index.html",
    "test:all": "npm run test && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "fix-all": "npm run format && biome check --write . && npm run typecheck",
    "clean": "rm -rf .next coverage playwright-report test-results *.tsbuildinfo || true",
    "clean:reports": "rm -rf playwright-report test-results coverage audit-outputs security-audit-history.json || true",
    "clean:cache": "rm -rf .next .swc node_modules/.cache || true",
    "clean:dev": "npm run clean && npm run dev",
    "clean:all": "npm run clean:reports && npm run clean:cache && rm -rf node_modules && npm install",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:quick": "npm run test && npm run test:dev",
    "test:full": "npm run test && npm run test:e2e",
    "test:ci": "jest --coverage --ci --maxWorkers=2",
    "test:e2e:ci": "playwright test --reporter=html",
    "lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./audit-outputs/lighthouse-report.html --view",
    "lighthouse:ci": "lhci autorun",
    "monitor:performance": "node scripts/performance-monitor.js",
    "monitor:performance:quick": "lhci collect --numberOfRuns=1 --no-upload",
    "audit:deps": "npm audit --audit-level=high",
    "audit:unused": "knip --no-exit-code",
    "audit:a11y": "jest --testPathPatterns=\\.axe\\.test\\. --no-coverage --passWithNoTests",
    "audit:security": "node scripts/security-audit.js",
    "audit:security:fix": "npm audit fix && npm run audit:security",
    "audit:perf": "npm run build && npm start & sleep 5 && npm run lighthouse",
    "audit:perf:ci": "npm run build && npm run monitor:performance",
    "update-deps": "npx npm-check-updates -u && npm install && npm test",
    "ci": "npm run fix-all && npm run build && npm run test:all",
    "prepare": "husky install || true",
    "dev-setup": "npm run clean:all && npm run fix-all && npm run dev",
    "dev:turbo": "next dev --turbo",
    "release": "npm run clean && npm run fix-all && npm run test && npm run build:analyze && npm run audit:deps",
    "monitor-all": "npm run audit:security && npm run bundle:analyze && npm run monitor:performance",
    "deploy": "npm run clean && npm run release && echo '✅ Ready for deployment!'",
    "debug": "npm run clean && npm run typecheck && npm run build",
    "linear": "node scripts/linear.js",
    "linear:list": "node scripts/linear.js list",
    "linear:me": "node scripts/linear.js list --me",
    "linear:create": "node scripts/linear.js create",
    "linear:delete": "node scripts/linear.js delete",
    "linear:cycles": "node scripts/linear.js cycles",
    "linear:projects": "node scripts/linear.js projects",
    "linear:info": "node scripts/linear.js info"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.4",
    "@next/third-parties": "^15.5.4",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^0.5.5",
    "@sentry/nextjs": "^10.19.0",
    "@types/exceljs": "^1.3.2",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.22",
    "gray-matter": "^4.0.3",
    "js-yaml": "3.14.1",
    "jspdf": "^3.0.3",
    "lru-cache": "^11.2.2",
    "lucide-react": "^0.545.0",
    "next": "^15.5.4",
    "next-contentlayer2": "^0.5.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.63.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-code-import": "^1.2.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.1.2",
    "shiki": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "overrides": {
    "gray-matter": {
      "js-yaml": "3.14.1"
    },
    "tmp": "^0.2.5",
    "inquirer": "^12.9.4",
    "external-editor": "^3.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@edge-runtime/jest-environment": "^4.0.0",
    "@lhci/cli": "^0.15.1",
    "@linear/sdk": "^60.0.0",
    "@next/bundle-analyzer": "^15.5.4",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.6.2",
    "@types/nodemailer": "^7.0.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "knip": "^5.64.1",
    "lighthouse": "^12.8.2",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "webpack": "^5.102.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "uk-tax-calculator",
    "paye-calculator",
    "hmrc-compliant",
    "next.js",
    "react",
    "typescript",
    "tailwind",
    "accessibility",
    "wcag",
    "financial-tools",
    "tax-planning",
    "tax-blog",
    "TaxInsights",
    "uk-tax-news",
    "tax-guidance",
    "tax-insights"
  ]
}

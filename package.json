{
  "name": "payetax",
  "version": "5.0.1",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "NODE_OPTIONS='--no-deprecation' next dev",
    "build": "next build --webpack",
    "build:analyze": "ANALYZE=true next build --webpack",
    "bundle:analyze": "bun scripts/bundle-analyzer.js",
    "bundle:monitor": "bun run build && bun run bundle:analyze",
    "start": "next start",
    "test": "jest --coverage && open audit-outputs/coverage/lcov-report/index.html",
    "test:watch": "jest --watch",
    "test:no-coverage": "jest --no-coverage",
    "test:changed": "jest --onlyChanged --no-coverage",
    "test:e2e": "playwright test --project=chromium --project=webkit --project='Mobile Chrome' --project='Mobile Safari' && (test -n \"$CI\" || open audit-outputs/playwright-report/index.html)",
    "test:dev": "playwright test --project=chromium && (test -n \"$CI\" || open audit-outputs/playwright-report/index.html)",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts e2e/calculator-critical.spec.ts e2e/director-guide-critical.spec.ts e2e/payslip-regression.spec.ts --project=chromium --workers=1 && (test -n \"$CI\" || open audit-outputs/playwright-report/index.html)",
    "test:e2e:golden": "playwright test e2e/golden-master-PERFECT.spec.ts --project=chromium --workers=1 && (test -n \"$CI\" || open audit-outputs/playwright-report/index.html)",
    "test:e2e:critical": "bun run test:e2e:smoke && bun run test:e2e:golden",
    "test:all": "bun run test && bun run test:e2e",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "fix-all": "biome check --write . && bun run typecheck && bun run check-version",
    "check-version": "bun scripts/check-version.ts",
    "audit:tokens": "tsx scripts/audit-tokens.ts",
    "audit:tokens:fix": "tsx scripts/audit-tokens.ts --fix",
    "notify-subscribers": "bun scripts/notify-subscribers.ts",
    "clean": "rm -rf .next coverage audit-outputs/playwright-report audit-outputs/test-results *.tsbuildinfo || true",
    "clean:reports": "rm -rf audit-outputs/playwright-report audit-outputs/test-results audit-outputs/coverage || true",
    "clean:cache": "rm -rf .next .swc node_modules/.cache || true",
    "clean:dev": "bun run clean && bun run dev",
    "clean:all": "bun run clean:reports && bun run clean:cache && rm -rf node_modules && bun install",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:quick": "bun run test && bun run test:dev",
    "test:full": "bun run test && bun run test:e2e",
    "test:ci": "jest --coverage --ci --maxWorkers=2",
    "test:e2e:ci": "playwright test --reporter=html",
    "test:e2e:clear": "rm -rf audit-outputs/playwright-report audit-outputs/test-results playwright/.auth/storageState.json && echo '✅ E2E test artifacts cleared'",
    "audit:deps": "bun pm scan",
    "audit:unused": "knip --no-exit-code",
    "audit:a11y": "jest --testPathPatterns=\\.axe\\.test\\. --no-coverage --passWithNoTests",
    "audit:security": "bun scripts/security-audit.js",
    "audit:security:fix": "bun pm audit --fix && bun run audit:security",
    "update-deps": "bun update && bun run test",
    "ci": "bun run fix-all && bun run build && bun run test:all",
    "dev-setup": "bun run clean:all && bun run fix-all && bun run dev",
    "dev:turbo": "next dev --turbo",
    "release": "bun run clean && bun run fix-all && bun run test && bun run build:analyze && bun run audit:deps",
    "monitor-all": "bun run audit:security && bun run bundle:analyze",
    "deploy": "bun run clean && bun run release && echo '✅ Ready for deployment!'",
    "debug": "bun run clean && bun run typecheck && bun run build",
    "linear": "bun scripts/linear.js",
    "linear:me": "bun scripts/linear.js list --me --project PayeTax",
    "linear:create": "bun scripts/linear.js create",
    "linear:done": "bun scripts/linear.js update-status",
    "golden:generate": "tsx e2e/scripts/generate-golden-master.ts"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "1.4.0",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "10.38.0",
    "@tailwindcss/typography": "0.5.19",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.34.0",
    "fuse.js": "7.1.0",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "lru-cache": "11.2.5",
    "lucide-react": "0.563.0",
    "next": "16.1.6",
    "next-mdx-remote": "5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.7.0",
    "rehype-pretty-code": "0.14.1",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "resend": "6.9.1",
    "shiki": "3.22.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "4.1.18",
    "zod": "4.3.6",
    "zustand": "5.0.11"
  },
  "overrides": {
    "tmp": "^0.2.5",
    "inquirer": "^12.9.4",
    "external-editor": "^3.1.0",
    "@opentelemetry/resources": "2.2.0",
    "@opentelemetry/core": "2.2.0",
    "@opentelemetry/sdk-trace-base": "2.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@biomejs/biome": "2.3.14",
    "@bun-security-scanner/osv": "1.0.0",
    "@linear/sdk": "74.0.0",
    "@next/bundle-analyzer": "16.1.6",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.1.18",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/github-slugger": "2.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.2.2",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "jest": "30.2.0",
    "jest-axe": "10.0.0",
    "jest-environment-jsdom": "30.2.0",
    "knip": "5.83.1",
    "sharp": "0.34.5",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "undici": "7.21.0",
    "webpack": "5.105.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "uk-tax-calculator",
    "paye-calculator",
    "hmrc-compliant",
    "next.js",
    "react",
    "typescript",
    "tailwind",
    "accessibility",
    "wcag",
    "financial-tools",
    "tax-planning",
    "tax-blog",
    "TaxInsights",
    "uk-tax-news",
    "tax-guidance",
    "tax-insights"
  ]
}

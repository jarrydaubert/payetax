{
  "name": "toolhubx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "fix-all": "concurrently \"npm run format\" \"npm run check\" \"npx tsc --noEmit\"",
    "post-change": "npm run fix-all && rm -rf .next && npm run dev",
    "lighthouse-check": "npx lighthouse http://localhost:3000 --view --quiet",
    "watch-post-change": "chokidar 'src/**/*' --ignore '.next/**' -c 'npm run post-change' --initial",
    "full-audit": "npm run fix-all && rm -rf .next && concurrently \"npm run dev\" \"sleep 10 && npm run lighthouse-check\"",
    "update-deps": "npx npm-check-updates -u && npm install"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.5.0",
    "@sentry/nextjs": "^10.5.0",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.540.0",
    "next": "^15.5.0",
    "nodemailer": "^7.0.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^10.1.0",
    "react-number-format": "^5.4.4",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "zod": "^4.0.17",
    "zustand": "^5.0.8"
  },
  "overrides": {
    "gray-matter": {
      "js-yaml": "^4.1.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@next/bundle-analyzer": "^15.5.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.0",
    "lighthouse": "^12.8.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3"
  },
  "keywords": [
    "uk-tax-calculator",
    "paye-calculator",
    "hmrc-compliant",
    "next.js",
    "react",
    "typescript",
    "tailwind",
    "accessibility",
    "wcag",
    "financial-tools",
    "tax-planning"
  ],
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}

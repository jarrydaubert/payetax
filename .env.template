# ============================================================================
# PayeTax Environment Configuration Template
# ============================================================================
# This is the master template showing all required environment variables.
# Copy this to .env.local and fill in your actual values.
#
# SECURITY: Never commit .env.local to Git!
# ============================================================================

# ----------------------------------------------------------------------------
# Analytics & Tracking
# ----------------------------------------------------------------------------

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com > Data Streams > Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ----------------------------------------------------------------------------
# Email System (Resend)
# ----------------------------------------------------------------------------

# Resend API Key for feedback and error monitoring emails
# Get from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000 emails/month
RESEND_API_KEY=

# Kit API Secret for newsletter subscribers
# Get from: https://app.kit.com/settings/developer
KIT_API_SECRET=

# Kit Form ID used by /api/newsletter/subscribe
# Get from Kit form URL or API
KIT_FORM_ID=

# Optional: Kit embed UID used in on-page newsletter embeds
# Defaults to 648a4b276a when unset
NEXT_PUBLIC_KIT_EMBED_UID=

# Optional: cache-bust value appended to Kit embed script URL
# Increase when Kit style updates seem stale (e.g. 2026-02-13-1)
NEXT_PUBLIC_KIT_EMBED_VERSION=

# Unsubscribe token signing secret (required in production)
# Generate: openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# ----------------------------------------------------------------------------
# Error Monitoring (Sentry)
# ----------------------------------------------------------------------------

# Sentry DSN (Data Source Name) for error tracking
# Get from: https://sentry.io/settings/payetax/projects/javascript-nextjs/keys/
# Free tier: 5,000 errors/month
# This is public and goes in the browser - it's safe to expose
NEXT_PUBLIC_SENTRY_DSN=

# Sentry Auth Token for uploading source maps (production builds)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, project:write
# IMPORTANT: Add this to Vercel environment variables (Production only)
# Do NOT commit this token - it's a secret
SENTRY_AUTH_TOKEN=

# Sentry Organization and Project (for CLI tools)
# These are used by Sentry CLI for source map uploads
SENTRY_ORG=payetax
SENTRY_PROJECT=javascript-nextjs

# Sentry webhook signature secret (required for /api/sentry-webhook)
SENTRY_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Vercel Deployment (For GitLab CI/CD)
# ----------------------------------------------------------------------------
# These go in GitLab Settings > CI/CD > Variables (NOT in .env.local)
# Get from Vercel Dashboard

# Vercel CLI Token
# Get from: https://vercel.com/account/tokens
# VERCEL_TOKEN=

# Vercel Organization/Team ID
# Get from: Vercel Dashboard > Project > Settings > General
# VERCEL_ORG_ID=

# Vercel Project ID
# Get from: Vercel Dashboard > Project > Settings > General
# VERCEL_PROJECT_ID=

# ----------------------------------------------------------------------------
# Feature Flags (Optional)
# ----------------------------------------------------------------------------

# Enable Progressive Web App features
NEXT_PUBLIC_ENABLE_PWA=true

# Enable Google Analytics tracking
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ----------------------------------------------------------------------------
# Security & Rate Limiting
# ----------------------------------------------------------------------------

# Upstash Redis REST credentials (recommended for distributed API rate limiting)
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# IndexNow submit auth secret for /api/indexnow writes
INDEXNOW_SUBMIT_SECRET=

# IndexNow key filename content (from your indexnow key file)
INDEXNOW_KEY=

# Partner notification inbox for referral lead route
REFERRAL_PARTNER_EMAIL=

# ----------------------------------------------------------------------------
# Build Configuration (Optional)
# ----------------------------------------------------------------------------

# Analyze bundle size during build (true to enable webpack-bundle-analyzer)
ANALYZE=false

# Node environment (development|production|test)
NODE_ENV=development

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# 1. Copy this file to .env.local: cp .env.template .env.local
# 2. Fill in all empty values with your actual credentials
# 3. For Vercel variables (VERCEL_*), add them to GitLab CI/CD Settings instead
# 4. See DEPLOYMENT_CHECKLIST.md for detailed setup instructions

# ============================================================================

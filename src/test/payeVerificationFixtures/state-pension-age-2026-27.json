{
  "suite": "State Pension age: NI exemption without any age-related allowance",
  "source": {
    "authority": "HMRC / UK Parliament",
    "urls": [
      "https://commonslibrary.parliament.uk/research-briefings/sn06158/",
      "https://www.gov.uk/income-tax-rates",
      "https://www.gov.uk/national-insurance-when-you-reach-state-pension-age",
      "https://www.gov.uk/guidance/rates-and-thresholds-for-employers-2026-to-2027"
    ],
    "taxYear": "2026-2027",
    "verifiedOn": "2026-07-18"
  },
  "tolerancePence": 2,
  "scenarios": [
    {
      "id": "spa-20k-age67",
      "description": "£20,000 at age 67 (the UI's over-SPA choice). Employee NI is exempt, but the Personal Allowance stays at the standard £12,570 — age-related allowances were abolished from 2016-17 (Finance Act 2015). Tax: taxable floor(1666.67-1048)=618 at 20% = £123.60/mo (£1,483.20/yr).",
      "input": {
        "salary": 20000,
        "payPeriod": "annually",
        "taxYear": "2026-2027",
        "taxCode": "1257L",
        "isScottish": false,
        "isMarried": false,
        "partnerGrossWage": 0,
        "isBlind": false,
        "age": 67,
        "payNoNI": false,
        "pensionContribution": 0,
        "pensionContributionType": "percentage",
        "studentLoanPlans": "none",
        "niCategory": "A",
        "hoursPerWeek": 40
      },
      "expected": {
        "taxFreeAmount": 12570,
        "incomeTaxAnnual": 1483.2,
        "nationalInsuranceAnnual": 0
      },
      "invariants": [
        "employee-ni-is-zero",
        "employer-ni-is-positive",
        "tax-free-amount-is-standard-personal-allowance"
      ]
    },
    {
      "id": "spa-20k-age78",
      "description": "£20,000 at age 78. Identical income tax to any other adult — no 75+ allowance exists in any supported tax year.",
      "input": {
        "salary": 20000,
        "payPeriod": "annually",
        "taxYear": "2026-2027",
        "taxCode": "1257L",
        "isScottish": false,
        "isMarried": false,
        "partnerGrossWage": 0,
        "isBlind": false,
        "age": 78,
        "payNoNI": false,
        "pensionContribution": 0,
        "pensionContributionType": "percentage",
        "studentLoanPlans": "none",
        "niCategory": "A",
        "hoursPerWeek": 40
      },
      "expected": {
        "taxFreeAmount": 12570,
        "incomeTaxAnnual": 1483.2,
        "nationalInsuranceAnnual": 0
      },
      "invariants": [
        "employee-ni-is-zero",
        "employer-ni-is-positive",
        "tax-free-amount-is-standard-personal-allowance"
      ]
    },
    {
      "id": "spa-20k-under-spa-baseline",

# PayeTax Environment Configuration

# M365 SMTP Configuration for Feedback & Error Reporting
M365_SMTP_HOST=smtp.office365.com
M365_SMTP_PORT=587
M365_EMAIL=your-email@domain.com
M365_PASSWORD=your-app-password-here

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Build Configuration
ANALYZE=false
NODE_ENV=development

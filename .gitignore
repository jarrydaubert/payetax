# Git ignore patterns for PayeTax. See https://git-scm.com/docs/gitignore for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# bun
bun.lockb

# testing (legacy, now in audit-outputs)
/coverage
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.template
.env.local
.env.production.local
.env.development.local
.env.test.local

# vercel
.vercel
.vercel.*
.vercel*

# typescript
*.tsbuildinfo
next-env.d.ts

# Build Caches
/.swc
.cache

# Contentlayer
.contentlayer

# Consolidated Audit & Reports Directory
/audit-outputs

# Legacy report paths (during migration) - NOW CLEANED UP
/playwright-report
/test-results
lighthouse-report.html
security-audit-history.json
/bundle-history.json

# Mac OS clutter
**/.DS_Store

# TypeScript build artifacts
playwright/.auth/
.env*.local

# Local caches
.npm/
.lighthouseci/

# Sentry Config File
.env.sentry-build-plugin

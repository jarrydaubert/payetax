#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run linting and type checking before commit
echo "🔍 Running pre-commit checks..."

# Run Biome linting
echo "📝 Linting with Biome..."
npm run lint || {
  echo "❌ Biome linting failed. Please fix errors before committing."
  exit 1
}

# Run TypeScript type checking
echo "🔷 Type checking with TypeScript..."
npm run typecheck || {
  echo "❌ TypeScript errors found. Please fix before committing."
  exit 1
}

# Run tests (quick unit tests only, not E2E)
echo "🧪 Running unit tests..."
npm run test:ci -- --bail --findRelatedTests || {
  echo "❌ Tests failed. Please fix before committing."
  exit 1
}

echo "✅ Pre-commit checks passed!"
